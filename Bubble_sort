#include <stdio.h>

void advancedBubbleSort(int arr[], int n) {
    int i, lastSwap, newn;
    while (n > 0) {
        lastSwap = 0;
        for (i = 1; i < n; i++) {
            if (arr[i - 1] > arr[i]) {
                // Swap
                int temp = arr[i - 1];
                arr[i - 1] = arr[i];
                arr[i] = temp;
                lastSwap = i;  // Update last swap position
            }
        }
        n = lastSwap;  // Reduce the range for next pass
        if (lastSwap == 0) {
            break;  // No swaps means array is sorted
        }
    }
}

void printArray(int arr[], int size) {
    for (int i = 0; i < size; i++)
        printf("%d ", arr[i]);
    printf("\n");
}

int main() {
    int arr[] = {5, 3, 8, 4, 2};
    int n = sizeof(arr) / sizeof(arr[0]);

    printf("Original array:\n");
    printArray(arr, n);

    advancedBubbleSort(arr, n);

    printf("Sorted array:\n");
    printArray(arr, n);

    return 0;
}
